			SulfurBar: {
				DisplayName: Серный слиток
				Tooltip:
					'''
					Примеси серы сделали сплав хрупким,
					но он, взамен, приобрёл скрытую силу.
					'Пылает внутренним жаром'
					'''
			}

			CinnabarBar: {
				DisplayName: Слиток киновари
				Tooltip:
