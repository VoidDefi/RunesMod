			BrainOfInfluence: {
				DisplayName: Мозг влияния
				Tooltip:
					'''
					Увеличивает концентрацию на 1.
					Есть шанс создать иллюзию и уклоняться от атаки
					Временно увеличивает шанс нанести критический удар после уклонения
					Может после удара приводить ближайших противников в замешательство
					'''
			}

			SulfurHelmet: {
				SetBonus:
					'''
					Даёт невосприимчивость к дебафам: '{0}' и '{1}'.
